{
  "auth": {
    "profiles": {
      "groq:main": {
        "provider": "groq",
        "mode": "api_key",
        "key": "${GROQ_API_KEY}"
      },
      "groq:backup": {
        "provider": "groq",
        "mode": "api_key",
        "key": "${GROQ_API_KEY_2}"
      },
      "openrouter:main": {
        "provider": "openrouter",
        "mode": "api_key",
        "key": "${OPENROUTER_API_KEY}"
      }
    },
    "order": {
      "groq": ["groq:main", "groq:backup"],
      "openrouter": ["openrouter:main"]
    }
  }
}
