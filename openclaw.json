{
  "gateway": {
    "mode": "local"
  },

  "agents": {
    "defaults": {
      "userTimezone": "Europe/Paris",

      "model": {
        "primary": "groq/llama-3.1-8b-instant",
        "fallbacks": [
          "groq/openai/gpt-oss-20b",
          "groq/llama-3.3-70b-versatile",
          "openrouter/openrouter/free"
        ]
      },

      "pdfModel": {
        "primary": "groq/openai/gpt-oss-20b",
        "fallbacks": [
          "groq/llama-3.1-8b-instant",
          "openrouter/openrouter/free"
        ]
      },

      "imageModel": {
        "primary": "openrouter/openrouter/free",
        "fallbacks": []
      },

      "models": {
        "groq/llama-3.1-8b-instant": {
          "alias": "groq-lite",
          "params": {
            "temperature": 0.2
          }
        },
        "groq/openai/gpt-oss-20b": {
          "alias": "groq-balanced",
          "params": {
            "temperature": 0.2
          }
        },
        "groq/llama-3.3-70b-versatile": {
          "alias": "groq-strong",
          "params": {
            "temperature": 0.2
          }
        },
        "openrouter/openrouter/free": {
          "alias": "backup-free",
          "params": {
            "temperature": 0.2
          }
        }
      },

      "compaction": {
        "enabled": true,
        "triggerFraction": 0.7,
        "targetFraction": 0.45,
        "memoryFlush": {
          "enabled": true
        }
      },

      "contextPruning": {
        "enabled": true,
        "keepRecentUserTurns": 8,
        "keepRecentAssistantTurns": 8,
        "keepRecentToolMessages": 12
      },

      "timeoutSeconds": 180,
      "contextTokens": 64000,
      "maxConcurrent": 1,
      "thinkingDefault": "low",
      "verboseDefault": "off",
      "elevatedDefault": "on"
    }
  },

  "tools": {
    "loopDetection": {
      "enabled": true
    },
    "web": {
      "fetch": {
        "enabled": true,
        "timeoutMs": 20000,
        "maxChars": 40000,
        "cacheTtlSeconds": 300
      }
    }
  },

  "browser": {
    "enabled": true,
    "evaluateEnabled": true,
    "defaultProfile": "openclaw",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": false
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "groq": {
        "baseUrl": "https://api.groq.com/openai/v1",
        "apiKey": "${GROQ_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "llama-3.1-8b-instant",
            "name": "Llama 3.1 8B Instant (Groq)"
          },
          {
            "id": "openai/gpt-oss-20b",
            "name": "GPT OSS 20B (Groq)"
          },
          {
            "id": "llama-3.3-70b-versatile",
            "name": "Llama 3.3 70B Versatile (Groq)"
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "openrouter/free",
            "name": "OpenRouter Free Router"
          }
        ]
      }
    }
  }
}
